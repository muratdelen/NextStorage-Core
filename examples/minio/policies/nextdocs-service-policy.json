{
  "Version": "2012-10-17",
  "Statement": [
    {
      "Effect": "Allow",
      "Action": [
        "s3:ListBucket",
        "s3:GetBucketLocation"
      ],
      "Resource": [
        "arn:aws:s3:::nextdocs-originals",
        "arn:aws:s3:::nextdocs-derived",
        "arn:aws:s3:::nextdocs-archive"
      ]
    },
    {
      "Effect": "Allow",
      "Action": [
        "s3:GetObject",
        "s3:PutObject",
        "s3:DeleteObject",
        "s3:GetObjectVersion",
        "s3:PutObjectTagging",
        "s3:GetObjectTagging"
      ],
      "Resource": [
        "arn:aws:s3:::nextdocs-originals/*",
        "arn:aws:s3:::nextdocs-derived/*",
        "arn:aws:s3:::nextdocs-archive/*"
      ]
    }
  ]
}
